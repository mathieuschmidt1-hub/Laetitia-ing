<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Laëtitia Ing — Céramiste</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=Inter:wght@300;400;500&display=swap" rel="stylesheet">
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --noir:    #0A0A0A;
      --creme:   #F7F4EE;
      --or:      #C4A96B;
      --ardoise: #3A3A3A;
      --or-pale: #E8D9B4;
    }

    html { scroll-behavior: smooth; }

    body {
      background: var(--noir);
      color: var(--creme);
      font-family: 'Inter', sans-serif;
      font-weight: 300;
      line-height: 1.7;
      overflow-x: hidden;
    }

    /* ── NAV ── */
    nav {
      position: fixed;
      top: 0; left: 0; right: 0;
      z-index: 100;
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 1.4rem 3rem;
      background: rgba(10,10,10,0.85);
      backdrop-filter: blur(10px);
      border-bottom: 1px solid rgba(196,169,107,0.15);
    }

    .nav-logo {
      font-family: 'Cormorant Garamond', serif;
      font-size: 1.2rem;
      font-weight: 300;
      letter-spacing: 0.2em;
      color: var(--or);
      text-transform: uppercase;
      text-decoration: none;
    }

    nav ul {
      list-style: none;
      display: flex;
      gap: 2.5rem;
    }

    nav a {
      text-decoration: none;
      color: var(--creme);
      font-size: 0.75rem;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      opacity: 0.7;
      transition: opacity 0.3s, color 0.3s;
    }
    nav a:hover { opacity: 1; color: var(--or); }

    /* ── HERO ── */
    #hero {
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      position: relative;
      overflow: hidden;
      padding: 0 3rem;
    }

    .hero-bg {
      position: absolute;
      inset: 0;
      background-image: url('photo-41.jpg');
      background-size: cover;
      background-position: center 30%;
      filter: brightness(0.22) saturate(0.6);
      transform: scale(1.04);
      transition: transform 12s ease;
    }
    #hero:hover .hero-bg { transform: scale(1.0); }

    .hero-content {
      position: relative;
      text-align: center;
      max-width: 700px;
    }

    .hero-eyebrow {
      display: block;
      font-size: 0.7rem;
      letter-spacing: 0.35em;
      text-transform: uppercase;
      color: var(--or);
      margin-bottom: 1.8rem;
      opacity: 0;
      animation: fadeUp 1s 0.3s forwards;
    }

    h1 {
      font-family: 'Cormorant Garamond', serif;
      font-size: clamp(3.5rem, 8vw, 7rem);
      font-weight: 300;
      line-height: 1.0;
      letter-spacing: -0.01em;
      margin-bottom: 1.6rem;
      opacity: 0;
      animation: fadeUp 1s 0.55s forwards;
    }

    h1 em {
      display: block;
      font-style: italic;
      color: var(--or-pale);
    }

    .hero-sub {
      font-size: 0.85rem;
      letter-spacing: 0.08em;
      color: rgba(247,244,238,0.55);
      margin-bottom: 3rem;
      opacity: 0;
      animation: fadeUp 1s 0.8s forwards;
    }

    .scroll-cue {
      position: absolute;
      bottom: 2.5rem;
      left: 50%;
      transform: translateX(-50%);
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 0.5rem;
      opacity: 0;
      animation: fadeUp 1s 1.4s forwards;
    }
    .scroll-cue span {
      font-size: 0.65rem;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: rgba(196,169,107,0.6);
    }
    .scroll-line {
      width: 1px;
      height: 40px;
      background: linear-gradient(to bottom, var(--or), transparent);
      animation: scrollPulse 2s infinite;
    }

    /* ── SECTION BASE ── */
    section { padding: 7rem 3rem; }

    .section-label {
      font-size: 0.65rem;
      letter-spacing: 0.3em;
      text-transform: uppercase;
      color: var(--or);
      margin-bottom: 3rem;
      display: flex;
      align-items: center;
      gap: 1rem;
    }
    .section-label::after {
      content: '';
      flex: 1;
      max-width: 60px;
      height: 1px;
      background: var(--or);
      opacity: 0.4;
    }

    /* ── PRÉSENTATION ── */
    #presentation {
      max-width: 1200px;
      margin: 0 auto;
    }

    .pres-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 5rem;
      align-items: start;
    }

    .pres-portrait {
      position: relative;
    }

    .pres-portrait img {
      width: 100%;
      aspect-ratio: 4/5;
      object-fit: cover;
      object-position: center 15%;
      display: block;
      filter: grayscale(20%) contrast(1.05);
    }

    .portrait-frame {
      position: absolute;
      inset: -10px;
      border: 1px solid rgba(196,169,107,0.25);
      pointer-events: none;
      transform: translate(12px, 12px);
    }

    .pres-text { padding-top: 1rem; }

    h2 {
      font-family: 'Cormorant Garamond', serif;
      font-size: clamp(2.2rem, 4vw, 3.5rem);
      font-weight: 300;
      line-height: 1.15;
      margin-bottom: 2rem;
      color: var(--creme);
    }

    h2 em { font-style: italic; color: var(--or-pale); }

    .pres-body p {
      font-size: 0.9rem;
      color: rgba(247,244,238,0.7);
      margin-bottom: 1.4rem;
      line-height: 1.85;
    }

    .pres-body p strong {
      color: var(--or);
      font-weight: 400;
    }

    .divider {
      width: 40px;
      height: 1px;
      background: var(--or);
      margin: 2.5rem 0;
      opacity: 0.5;
    }

    .pres-quote {
      font-family: 'Cormorant Garamond', serif;
      font-style: italic;
      font-size: 1.35rem;
      color: var(--or-pale);
      line-height: 1.6;
      border-left: 1px solid rgba(196,169,107,0.4);
      padding-left: 1.5rem;
      margin: 2rem 0;
    }

    /* ── GALERIE ── */
    #galerie {
      background: #070707;
      border-top: 1px solid rgba(196,169,107,0.1);
    }

    #galerie .inner {
      max-width: 1200px;
      margin: 0 auto;
    }

    .gallery-intro {
      display: flex;
      align-items: flex-end;
      justify-content: space-between;
      margin-bottom: 4rem;
      gap: 2rem;
    }

    .gallery-intro h2 { margin-bottom: 0; }

    .gallery-intro p {
      font-size: 0.8rem;
      color: rgba(247,244,238,0.4);
      letter-spacing: 0.05em;
      max-width: 260px;
      text-align: right;
    }

    /* Masonry layout */
    .gallery-masonry {
      columns: 3;
      column-gap: 1.2rem;
    }

    .gallery-item {
      break-inside: avoid;
      margin-bottom: 1.2rem;
      position: relative;
      overflow: hidden;
      cursor: pointer;
    }

    .gallery-item img {
      width: 100%;
      display: block;
      transition: transform 0.6s cubic-bezier(0.25,0.46,0.45,0.94), filter 0.6s;
      filter: brightness(0.88) saturate(0.9);
    }

    .gallery-item:hover img {
      transform: scale(1.04);
      filter: brightness(1) saturate(1);
    }

    .gallery-overlay {
      position: absolute;
      inset: 0;
      background: linear-gradient(to top, rgba(10,10,10,0.8) 0%, transparent 60%);
      opacity: 0;
      transition: opacity 0.4s;
      display: flex;
      align-items: flex-end;
      padding: 1.5rem;
    }

    .gallery-item:hover .gallery-overlay { opacity: 1; }

    .gallery-caption {
      font-family: 'Cormorant Garamond', serif;
      font-style: italic;
      font-size: 0.95rem;
      color: var(--or-pale);
      letter-spacing: 0.05em;
    }

    /* Lightbox */
    .lightbox {
      display: none;
      position: fixed;
      inset: 0;
      z-index: 200;
      background: rgba(5,5,5,0.96);
      align-items: center;
      justify-content: center;
      padding: 2rem;
    }
    .lightbox.open { display: flex; }

    .lightbox img {
      max-width: 90vw;
      max-height: 88vh;
      object-fit: contain;
      box-shadow: 0 0 80px rgba(0,0,0,0.8);
    }

    .lightbox-close {
      position: absolute;
      top: 1.5rem; right: 2rem;
      background: none;
      border: none;
      color: var(--or);
      font-size: 2rem;
      cursor: pointer;
      font-family: 'Cormorant Garamond', serif;
      opacity: 0.7;
      transition: opacity 0.2s;
    }
    .lightbox-close:hover { opacity: 1; }

    .lb-nav {
      position: absolute;
      top: 50%;
      transform: translateY(-50%);
      background: none;
      border: 1px solid rgba(196,169,107,0.3);
      color: var(--or);
      width: 44px; height: 44px;
      display: flex; align-items: center; justify-content: center;
      cursor: pointer;
      font-size: 1.2rem;
      transition: background 0.2s, border-color 0.2s;
    }
    .lb-nav:hover { background: rgba(196,169,107,0.1); border-color: var(--or); }
    .lb-prev { left: 1.5rem; }
    .lb-next { right: 1.5rem; }

    .lb-caption {
      position: absolute;
      bottom: 1.5rem;
      left: 50%; transform: translateX(-50%);
      font-family: 'Cormorant Garamond', serif;
      font-style: italic;
      color: var(--or-pale);
      font-size: 0.9rem;
      letter-spacing: 0.08em;
      opacity: 0.7;
    }

    /* ── CONTACT ── */
    #contact {
      text-align: center;
      border-top: 1px solid rgba(196,169,107,0.1);
      max-width: 600px;
      margin: 0 auto;
    }

    #contact h2 { margin-bottom: 1rem; }

    #contact p {
      font-size: 0.85rem;
      color: rgba(247,244,238,0.5);
      margin-bottom: 2.5rem;
    }

    .contact-link {
      display: inline-block;
      color: var(--or);
      text-decoration: none;
      font-family: 'Cormorant Garamond', serif;
      font-size: 1.3rem;
      font-style: italic;
      border-bottom: 1px solid rgba(196,169,107,0.3);
      padding-bottom: 0.2rem;
      transition: border-color 0.3s, color 0.3s;
    }
    .contact-link:hover { color: var(--or-pale); border-color: var(--or); }

    /* ── FOOTER ── */
    footer {
      text-align: center;
      padding: 2rem 3rem;
      border-top: 1px solid rgba(196,169,107,0.08);
      font-size: 0.7rem;
      letter-spacing: 0.12em;
      color: rgba(247,244,238,0.2);
    }

    /* ── ANIMATIONS ── */
    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(20px); }
      to   { opacity: 1; transform: translateY(0); }
    }
    @keyframes scrollPulse {
      0%, 100% { opacity: 0.3; }
      50%       { opacity: 1; }
    }

    .reveal {
      opacity: 0;
      transform: translateY(28px);
      transition: opacity 0.8s ease, transform 0.8s ease;
    }
    .reveal.visible {
      opacity: 1;
      transform: none;
    }

    /* ── RESPONSIVE ── */
    @media (max-width: 900px) {
      nav { padding: 1.2rem 1.5rem; }
      section { padding: 5rem 1.5rem; }
      .pres-grid { grid-template-columns: 1fr; gap: 3rem; }
      .gallery-masonry { columns: 2; }
      .gallery-intro { flex-direction: column; align-items: flex-start; }
      .gallery-intro p { text-align: left; max-width: 100%; }
    }

    @media (max-width: 560px) {
      .gallery-masonry { columns: 1; }
      nav ul { gap: 1.2rem; }
    }
  </style>
</head>
<body>

  <!-- NAV -->
  <nav>
    <a href="#hero" class="nav-logo">Laëtitia Ing</a>
    <ul>
      <li><a href="#presentation">Présentation</a></li>
      <li><a href="#galerie">Galerie</a></li>
      <li><a href="#contact">Contact</a></li>
    </ul>
  </nav>

  <!-- HERO -->
  <section id="hero">
    <div class="hero-bg"></div>
    <div class="hero-content">
      <span class="hero-eyebrow">Céramiste · Bruxelles</span>
      <h1>Laëtitia<em>Ing</em></h1>
      <p class="hero-sub">La terre comme langage — entre fragilité et permanence</p>
    </div>
    <div class="scroll-cue">
      <span>Découvrir</span>
      <div class="scroll-line"></div>
    </div>
  </section>

  <!-- PRÉSENTATION -->
  <section id="presentation">
    <div class="section-label">L'artiste</div>
    <div class="pres-grid">
      <div class="pres-portrait reveal">
        <img src="photo-193.jpg" alt="Portrait de Laëtitia Ing">
        <div class="portrait-frame"></div>
      </div>
      <div class="pres-text reveal">
        <h2>Entre la terre<em>et le silence</em></h2>
        <div class="pres-body">
          <p>Laëtitia Ing est céramiste, dont le travail naît d'une relation intime et patiente avec la matière. <strong>Argile, émaux, fleurs sculptées</strong> — chaque pièce est une conversation entre la forme et le hasard, entre ce qu'on contrôle et ce que le feu décide.</p>
          <p>Son univers s'articule autour de deux langages plastiques : des <strong>sculptures murales</strong> aux surfaces froissées, couvertes d'éclosions florales en céramique colorée, et des <strong>formes libres</strong> aux contours organiques — bassins, vases, volumes — qui semblent avoir poussé plutôt qu'été fabriqués.</p>
          <div class="divider"></div>
          <blockquote class="pres-quote">
            "Everything will be fine" — les mots apparaissent dans la terre comme une promesse gravée dans ce qui dure.
          </blockquote>
          <p>Formée aux arts plastiques et à la céramique artisanale, Laëtitia explore la tension entre <strong>douceur et résistance</strong>, entre le message humain et la permanence minérale. Ses pièces exposées à L'Atelier témoignent d'une pratique singulière, profondément personnelle.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- GALERIE -->
  <section id="galerie">
    <div class="inner">
      <div class="section-label">Œuvres</div>
      <div class="gallery-intro reveal">
        <h2>La <em>galerie</em></h2>
        <p>Exposition L'Atelier — cliquez sur une œuvre pour l'explorer</p>
      </div>
      <div class="gallery-masonry" id="gallery">
        <div class="gallery-item reveal" data-index="0" data-caption="Sculptures murales — Série florale, émail sur argile">
          <img src="photo-41.jpg" alt="Sculptures murales avec fleurs céramiques et inscriptions">
          <div class="gallery-overlay"><span class="gallery-caption">Série florale — murale</span></div>
        </div>
        <div class="gallery-item reveal" data-index="1" data-caption="Compositions organiques — grès et émail bleu cobalt">
          <img src="photo-42.jpg" alt="Céramiques organiques - vasque et vase">
          <div class="gallery-overlay"><span class="gallery-caption">Formes organiques</span></div>
        </div>
        <div class="gallery-item reveal" data-index="2" data-caption="Fleur en bronze sur plateau — détail, lustre or">
          <img src="photo-43.jpg" alt="Fleur céramique en bronze dorée sur plateau">
          <div class="gallery-overlay"><span class="gallery-caption">Fleur dorée — détail</span></div>
        </div>
        <div class="gallery-item reveal" data-index="3" data-caption="Vase sculpté — rose noire sur socle texturé doré">
          <img src="photo-44.jpg" alt="Vase céramique avec rose noire et socle doré">
          <div class="gallery-overlay"><span class="gallery-caption">Rose noire</span></div>
        </div>
      </div>
    </div>
  </section>

  <!-- CONTACT -->
  <section id="contact">
    <div class="section-label">Échanger</div>
    <h2>Entrer en<em>contact</em></h2>
    <p>Pour toute demande d'acquisition, de collaboration ou d'exposition, n'hésitez pas à me contacter.</p>
    <a href="mailto:contact@laetitia-ing.be" class="contact-link">contact@laetitia-ing.be</a>
  </section>

  <!-- FOOTER -->
  <footer>
    <p>© 2025 Laëtitia Ing — Tous droits réservés</p>
  </footer>

  <!-- LIGHTBOX -->
  <div class="lightbox" id="lightbox" role="dialog" aria-modal="true">
    <button class="lightbox-close" id="lb-close" aria-label="Fermer">×</button>
    <button class="lb-nav lb-prev" id="lb-prev" aria-label="Précédent">‹</button>
    <img id="lb-img" src="" alt="">
    <button class="lb-nav lb-next" id="lb-next" aria-label="Suivant">›</button>
    <span class="lb-caption" id="lb-caption"></span>
  </div>

  <script>
    // Reveal on scroll
    const reveals = document.querySelectorAll('.reveal');
    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry, i) => {
        if (entry.isIntersecting) {
          setTimeout(() => entry.target.classList.add('visible'), 100 * (Array.from(reveals).indexOf(entry.target) % 4));
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.12 });
    reveals.forEach(el => observer.observe(el));

    // Lightbox
    const items = document.querySelectorAll('.gallery-item');
    const lb = document.getElementById('lightbox');
    const lbImg = document.getElementById('lb-img');
    const lbCap = document.getElementById('lb-caption');
    let current = 0;
    const images = Array.from(items).map(item => ({
      src: item.querySelector('img').src,
      caption: item.dataset.caption
    }));

    function openLb(index) {
      current = index;
      lbImg.src = images[current].src;
      lbCap.textContent = images[current].caption;
      lb.classList.add('open');
      document.body.style.overflow = 'hidden';
    }
    function closeLb() {
      lb.classList.remove('open');
      document.body.style.overflow = '';
    }
    function navLb(dir) {
      current = (current + dir + images.length) % images.length;
      lbImg.src = images[current].src;
      lbCap.textContent = images[current].caption;
    }

    items.forEach((item, i) => item.addEventListener('click', () => openLb(i)));
    document.getElementById('lb-close').addEventListener('click', closeLb);
    document.getElementById('lb-prev').addEventListener('click', () => navLb(-1));
    document.getElementById('lb-next').addEventListener('click', () => navLb(1));
    lb.addEventListener('click', e => { if (e.target === lb) closeLb(); });
    document.addEventListener('keydown', e => {
      if (!lb.classList.contains('open')) return;
      if (e.key === 'Escape') closeLb();
      if (e.key === 'ArrowLeft') navLb(-1);
      if (e.key === 'ArrowRight') navLb(1);
    });
  </script>
</body>
</html>
